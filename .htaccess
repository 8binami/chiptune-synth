RewriteEngine On
RewriteBase /8b/com.8binami.github.chiptune-synth/

# Proprietary engine: redirect source → obfuscated dist
RewriteRule ^src/chiptune-synth\.js$ dist/chiptune-synth.min.js [L,R=301]

# Dist + Codepen folders: serve directly (standalone HTML + built assets)
RewriteRule ^(dist|codepen)/ - [L]

# Static assets: serve directly (CSS, JS, images, fonts, audio, etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteCond %{REQUEST_URI} !\.html$
RewriteRule ^ - [L]

# Directories: serve directly
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# SEO files → front controller (served from .server/ if present)
RewriteRule ^robots\.txt$ index.php [L]
RewriteRule ^llms\.txt$ index.php [L]
RewriteRule ^sitemap\.xml$ index.php [L]

# Language-prefixed static assets → strip prefix and serve file directly
# Handles /zh/src/file.js, /fr/assets/img.png, etc.
RewriteCond %{DOCUMENT_ROOT}/$2 -f
RewriteRule ^(en|fr|ja|de|es|zh|pt|it|ko|ru)/(.+\.(js|css|png|jpg|jpeg|gif|svg|woff2?|ttf|eot|ico|mp3|wav|ogg|webp|json|map))$ $2 [L]

# Language-prefixed URLs → front controller
RewriteRule ^(en|fr|ja|de|es|zh|pt|it|ko|ru)(/.*)?$ index.php [QSA,L]

# Everything else → front controller (clean URLs, .html legacy, root)
RewriteRule ^(.*)$ index.php [QSA,L]
